# 数据库连接配置

# CockroachDB (即时数据)
COCKROACHDB_URL="postgresql://root:your-password@your-cluster.cockroachlabs.cloud:26257/defaultdb?sslmode=verify-full"

# TiDB Cloud (日备份数据 - 替代Supabase/PlanetScale)
TIDB_HOST="gateway01.ap-southeast-1.prod.aws.tidbcloud.com"
TIDB_PORT="4000"
TIDB_USER="your-tidb-user"
TIDB_PASSWORD="your-tidb-password"
TIDB_DATABASE="test"

# Neon (备份数据)
NEON_URL="postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require"

# Railway (临时数据)
RAILWAY_URL="postgresql://user:password@your-railway-host.railway.app:5432/railway"

# 端口
PORT=3001

# 邮件服务配置 (用于发送验证码)
# 支持: 'QQ', '163', 'Gmail', 'Outlook' 等
EMAIL_SERVICE="QQ"
EMAIL_USER="your-email@qq.com"
EMAIL_PASSWORD="your-email-authorization-code"

# Twilio配置 (用于短信验证码 - 可选)
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="your-twilio-phone-number"

# JWT密钥 (用于生成token)
JWT_SECRET="your-jwt-secret"