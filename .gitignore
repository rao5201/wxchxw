# ===================== Node.js 核心忽略 =====================
# 依赖包目录（无需提交到Git，部署时Netlify会自动安装）
node_modules/
# npm 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# 包管理锁文件（可选忽略，建议保留package-lock.json/yarn.lock）
# package-lock.json
# yarn.lock

# ===================== 环境变量/敏感配置 =====================
# 本地环境变量文件（存放数据库密码、加密密钥等，绝对不能提交）
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# 环境变量示例文件（可选保留）
.env.example

# ===================== 构建产物/缓存 =====================
# 前端构建产物（如React/Vue/静态站点打包后的目录）
build/
dist/
out/
# 缓存目录
.cache/
.npm/
# Netlify 构建缓存
.netlify/

# ===================== 编辑器/IDE 配置 =====================
# VSCode
.vscode/
.idea/
# Sublime
*.sublime-project
*.sublime-workspace
# Vim
*.swp
*.swo
# macOS 系统文件
.DS_Store
# Windows 系统文件
Thumbs.db
desktop.ini

# ===================== 日志/临时文件 =====================
# 日志文件
logs/
*.log
# 临时文件
tmp/
temp/
# 压缩包
*.zip
*.tar.gz
*.rar

# ===================== 自定义忽略（项目专属） =====================
# 如果有本地测试的静态资源/大文件，可添加此处
# test-assets/
# large-files/
